{
  "name": "fiitx-desktop",
  "version": "0.1.0",
  "description": "Fiitx BYOM Agent Desktop for Enterprise",
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5191 --strictPort\" \"wait-on http://127.0.0.1:5191 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5191 electron .\"",
    "build": "tsc -b && vite build",
    "start": "electron .",
    "dist": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.1",
    "@earendil-works/pi-ai": "^0.78.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "ai.fiitx.desktop",
    "productName": "Fiitx",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/fiitx.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
