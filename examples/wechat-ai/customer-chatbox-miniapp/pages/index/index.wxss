.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: 36rpx 28rpx 24rpx;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  color: #5f6f89;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.title {
  color: #101827;
  font-size: 44rpx;
  font-weight: 800;
}

.subtitle {
  color: #66758c;
  font-size: 26rpx;
  line-height: 1.5;
}

.messages {
  flex: 1;
  min-height: 0;
}

.message {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #dde5f2;
  border-radius: 18rpx;
  background: #ffffff;
}

.message.user {
  margin-left: 64rpx;
  border-color: #bfd7ff;
  background: #eef5ff;
}

.message.agent {
  margin-right: 64rpx;
}

.author {
  color: #42516a;
  font-size: 24rpx;
  font-weight: 700;
}

.body {
  color: #172033;
  font-size: 30rpx;
  line-height: 1.55;
}

.card {
  margin: 22rpx 0;
  padding: 24rpx;
  border: 1rpx solid #c7dcff;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(27, 89, 180, 0.08);
}

.card-head {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 16rpx;
}

.card-kicker {
  color: #1f6feb;
  font-size: 22rpx;
  font-weight: 700;
}

.card-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.card-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 12rpx 0;
  color: #4b5870;
  font-size: 26rpx;
  border-top: 1rpx solid #edf1f7;
}

.card-row-value {
  max-width: 430rpx;
  text-align: right;
}

.card-action {
  width: 100%;
  height: 82rpx;
  margin: 18rpx 0 8rpx;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  background: #1f6feb;
}

.card-action-pay {
  background: #159947;
}

.paid-banner {
  margin: 18rpx 0 8rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #bdeccf;
  border-radius: 16rpx;
  color: #116b34;
  font-size: 27rpx;
  font-weight: 700;
  background: #edfff3;
}

.card-json {
  display: block;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #111827;
  color: #d8e2f2;
  font-family: Menlo, Consolas, monospace;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}

.composer {
  display: flex;
  gap: 14rpx;
  padding-top: 18rpx;
}

.input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d9e2ef;
  border-radius: 18rpx;
  background: #ffffff;
  font-size: 28rpx;
}

.send {
  width: 148rpx;
  height: 88rpx;
  color: #ffffff;
  font-size: 28rpx;
  background: #1f6feb;
}
