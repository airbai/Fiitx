    "resume": "node agent.mjs --resume"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.16",
    "cheerio": "^1.0.0",
    "puppeteer": "^24.0.0",
    "sharp": "^0.33.5"
  },
  "optionalDependencies": {
    "openai": "^4.73.0"
  }
}
