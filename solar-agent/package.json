{
  "name": "solar-agent",
  "version": "1.0.0",
  "description": "全网自动搜索有户型图别墅 → 生成太阳能板实景图 → 报价 → 自动发邮件给房东",
  "type": "module",
  "main": "agent.mjs",
  "scripts": {
    "start": "node agent.mjs",
